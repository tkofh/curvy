{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": "warn",
        "noUselessTernary": "warn",
        "noVoid": "warn",
        "useLiteralKeys": "off",
        "useSimplifiedLogicExpression": "warn"
      },
      "correctness": {
        "noUnusedPrivateClassMembers": "error",
        "noUnusedVariables": "warn",
        "noUnusedImports": "error",
        "noInvalidBuiltinInstantiation": "error",
        "noSwitchDeclarations": "warn"
      },
      "performance": {
        "noBarrelFile": "warn",
        "noReExportAll": "error"
      },
      "style": {
        "noDefaultExport": "error",
        "noNamespace": "error",
        "useCollapsedElseIf": "error",
        "useBlockStatements": "error",
        "useNamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false
          }
        },
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false
          }
        },
        "useImportType": "error",
        "useExportType": "error",
        "useConsistentArrayType": {
          "level": "error",
          "options": {
            "syntax": "generic"
          }
        },
        "useShorthandAssign": "error"
      },
      "suspicious": {
        "noApproximativeNumericConstant": "error",
        "noEmptyBlockStatements": "off",
        "useAwait": "warn",
        "noDuplicateElseIf": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "quoteStyle": "single",
      "arrowParentheses": "always"
    }
  },
  "overrides": [
    {
      "includes": ["**/*.config.ts"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    }
  ]
}
