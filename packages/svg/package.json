{
  "name": "@curvy/svg",
  "version": "0.0.8",
  "description": "Spline and Curve utilities for SVG",
  "author": "Tim Morris <timthewebguy@gmail.com>",
  "homepage": "https://github.com/tkofh/curvy#readme",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./path": {
      "types": "./dist/path.d.mts",
      "import": "./dist/path.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tkofh/curvy.git"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "bugs": {
    "url": "https://github.com/tkofh/curvy/issues"
  },
  "dependencies": {
    "curvy": "workspace:*"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
