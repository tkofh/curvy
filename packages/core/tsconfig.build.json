{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "stripInternal": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["test/**/*", "node_modules", "dist"]
}
