{
  "name": "curvy",
  "version": "1.0.9",
  "description": "Spline and Curve utilities",
  "author": "Tim Morris <timthewebguy@gmail.com>",
  "homepage": "https://github.com/tkofh/curvy#readme",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./vector2": {
      "types": "./dist/vector/vector2.d.mts",
      "import": "./dist/vector/vector2.mjs"
    },
    "./vector3": {
      "types": "./dist/vector/vector3.d.mts",
      "import": "./dist/vector/vector3.mjs"
    },
    "./vector4": {
      "types": "./dist/vector/vector4.d.mts",
      "import": "./dist/vector/vector4.mjs"
    },
    "./matrix2x2": {
      "types": "./dist/matrix/matrix2x2.d.mts",
      "import": "./dist/matrix/matrix2x2.mjs"
    },
    "./matrix3x3": {
      "types": "./dist/matrix/matrix3x3.d.mts",
      "import": "./dist/matrix/matrix3x3.mjs"
    },
    "./matrix4x4": {
      "types": "./dist/matrix/matrix4x4.d.mts",
      "import": "./dist/matrix/matrix4x4.mjs"
    },
    "./curve/linear2d": {
      "types": "./dist/curve/linear2d.d.mts",
      "import": "./dist/curve/linear2d.mjs"
    },
    "./curve/quadratic2d": {
      "types": "./dist/curve/quadratic2d.d.mts",
      "import": "./dist/curve/quadratic2d.mjs"
    },
    "./curve/cubic2d": {
      "types": "./dist/curve/cubic2d.d.mts",
      "import": "./dist/curve/cubic2d.mjs"
    },
    "./polynomial/linear": {
      "types": "./dist/polynomial/linear.d.mts",
      "import": "./dist/polynomial/linear.mjs"
    },
    "./polynomial/quadratic": {
      "types": "./dist/polynomial/quadratic.d.mts",
      "import": "./dist/polynomial/quadratic.mjs"
    },
    "./polynomial/cubic": {
      "types": "./dist/polynomial/cubic.d.mts",
      "import": "./dist/polynomial/cubic.mjs"
    },
    "./interval": {
      "types": "./dist/interval.d.mts",
      "import": "./dist/interval.mjs"
    },
    "./path/linear2d": {
      "types": "./dist/path/linear2d.d.mts",
      "import": "./dist/path/linear2d.mjs"
    },
    "./path/quadratic2d": {
      "types": "./dist/path/quadratic2d.d.mts",
      "import": "./dist/path/quadratic2d.mjs"
    },
    "./path/cubic2d": {
      "types": "./dist/path/cubic2d.d.mts",
      "import": "./dist/path/cubic2d.mjs"
    },
    "./splines/bezier2d": {
      "types": "./dist/splines/bezier2d.d.mts",
      "import": "./dist/splines/bezier2d.mjs"
    },
    "./splines/hermite2d": {
      "types": "./dist/splines/hermite2d.d.mts",
      "import": "./dist/splines/hermite2d.mjs"
    },
    "./splines/cardinal2d": {
      "types": "./dist/splines/cardinal2d.d.mts",
      "import": "./dist/splines/cardinal2d.mjs"
    },
    "./splines/basis2d": {
      "types": "./dist/splines/basis2d.d.mts",
      "import": "./dist/splines/basis2d.mjs"
    },
    "./pipe": {
      "types": "./dist/pipe.d.mts",
      "import": "./dist/pipe.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.mts",
      "import": "./dist/utils.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tkofh/curvy.git"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "typecheck": "tsc --noEmit"
  },
  "bugs": {
    "url": "https://github.com/tkofh/curvy/issues"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
